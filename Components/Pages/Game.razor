@page "/game"
@using Microsoft.AspNetCore.SignalR.Client
@using MyBlazorApp.Models
@using MyBlazorApp.Services
@using Microsoft.JSInterop
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject GameInputService InputService
@inject GameAiService AiService

@implements IAsyncDisposable

<h3>멀티 RPG 테스트</h3>

@if (!joined)
{
    <div class="join-box">
        <input @bind="playerName" placeholder="닉네임" />
        <input @bind="roomCode" placeholder="방 코드" />
        <button @onclick="JoinGame">입장</button>
    </div>
}
else
{
    <div class="game-area">
        <!-- ============================== -->
        <!-- 타일 맵 -->
        <!-- ============================== -->
        <div class="tile-map">
            @for (int y = 0; y < 13; y++)
            {
                @for (int x = 0; x < 20; x++)
                {
                    <div class="@GetTileClass(x, y)"></div>
                }
            }
        </div>

        <div class="map-name">현재 맵: @GetMapName(myCurrentMap)</div>

        <!-- ============================== -->
        <!-- 포탈 -->
        <!-- ============================== -->
        @foreach (var portal in portals.Where(p => p.FromMap == myCurrentMap))
        {
            <div class="portal" style="left:@($"{portal.X}px"); top:@($"{portal.Y}px");">
                🌀
                <div>@portal.Name</div>
            </div>
        }

        @if (showPortalConfirm && selectedPortal != null)
        {
            <div class="portal-confirm">
                <h4>포탈 이동</h4>
                <p>@selectedPortal.Message</p>
                <div class="portal-buttons">
                    <button @onclick="ConfirmPortalMove">예</button>
                    <button @onclick="CancelPortalMove">아니오</button>
                </div>
            </div>
        }

        <!-- ============================== -->
        <!-- NPC / 상점 / 퀘스트 -->
        <!-- ============================== -->
        @foreach (var npc in npcs.Where(n => myCurrentMap == MapType.Town))
        {
            <div class="npc" style="left:@($"{npc.X}px"); top:@($"{npc.Y}px");">
                <div class="name">@npc.Name</div>
                <img src="/images/npc/shopkeeper.png" class="npc-img" />
            </div>
        }

        @if (showNpcDialog)
        {
            <div class="npc-dialog">@npcMessage</div>
        }

        @if (showShop && selectedNpc != null)
        {
            <div class="shop-box quest-box">
                <h4>@selectedNpc.Name</h4>
                <p>@selectedNpc.Message</p>

                @{
                    var quest = questDefinitions.FirstOrDefault(q => q.QuestId == selectedNpc.QuestId);
                    var myQuest = myQuests.FirstOrDefault(q => q.QuestId == selectedNpc.QuestId);
                }

                @if (quest != null)
                {
                    <div class="quest-panel">
                        <strong>@quest.QuestName</strong>
                        <p>@quest.Description</p>

                        @if (myQuest == null)
                        {
                            <button @onclick="async () => await AcceptQuest(quest.QuestId)">퀘스트 받기</button>
                        }
                        else if (myQuest.Completed && !myQuest.RewardReceived)
                        {
                            <button @onclick="async () => await ReceiveQuestReward(quest.QuestId)">보상 받기</button>
                        }
                        else if (myQuest.RewardReceived)
                        {
                            <span class="quest-complete">완료됨</span>
                        }
                        else
                        {
                            <span>@myQuest.CurrentCount / @quest.RequiredCount</span>
                        }
                    </div>
                }

                @if (selectedNpc.Name == "상인")
                {
                    <button @onclick="BuyPotion">작은 포션 구매 - 20 Gold</button>
                }

                <button @onclick="CloseShop">닫기</button>
            </div>
        }

        <!-- ============================== -->
        <!-- 상태창 -->
        <!-- ============================== -->
        <div class="status-box">
            <div>닉네임: @playerName</div>
            <div>직업: @GetJobName(myJob)</div>
            <div>HP: @myHp / @myMaxHp</div>
            <div>Lv: @myLevel</div>
            <div>EXP: @myExp / @(myLevel * 30)</div>
            <div>Gold: @myGold</div>
            <div>공격력: @myAttackPower</div>
            <div>방어력: @myDefense</div>
            <div>스킬포인트: @mySkillPoint</div>
            <div>Dash: @(canDash ? "가능" : "쿨타임")</div>
        </div>

        <!-- ============================== -->
        <!-- 플레이어 -->
        <!-- ============================== -->
        <div class="player @(isDashing ? "dash-effect" : "")" style="left:@($"{myX}px"); top:@($"{myY}px");">
            <div class="name">@playerName</div>
            <img src="@playerImage" class="player-img" />
        </div>

        @foreach (var player in players.Where(p => p.Name != playerName && p.CurrentMap == myCurrentMap))
        {
            <div class="player" style="left:@($"{player.X}px"); top:@($"{player.Y}px");">
                <div class="name">@player.Name</div>
                <img src="/images/player/down.png" class="player-img" />
            </div>
        }

        <!-- ============================== -->
        <!-- 몬스터 / 드랍 -->
        <!-- ============================== -->
        @foreach (var monster in monsters)
        {
            <div class="monster" style="left:@($"{monster.X}px"); top:@($"{monster.Y}px");">
                <img src="@GetMonsterImage(monster.Type)" class="monster-img" />
                <div class="monster-name">@monster.Name</div>
                <div class="monster-hp">HP: @monster.Hp / @monster.MaxHp</div>
            </div>
        }

        @foreach (var item in droppedItems)
        {
            <div class="drop-item" style="left:@($"{item.X}px"); top:@($"{item.Y}px");">
                @if (item.IsGold)
                {
                    <div class="drop-gold">💰 @item.GoldAmount</div>
                }
                else
                {
                    <div class="drop-loot rarity-@item.Rarity.ToLower()">📦 @item.Name</div>
                }
            </div>
        }

        <!-- ============================== -->
        <!-- 인벤토리 -->
        <!-- ============================== -->
        @if (showInventory)
        {
            <div class="inventory-box">
                <h4>인벤토리</h4>

                @if (myInventory.Count == 0)
                {
                    <p>아이템 없음</p>
                }
                else
                {
                    @foreach (var item in myInventory)
                    {
                        var currentItemName = item.Name;
                        <div class="inventory-item rarity-@item.Rarity.ToLower()">
                            <div>
                                <strong>@item.Name</strong>
                                <span>x @item.Count</span>
                                @if (item.ItemType == "Weapon")
                                {
                                    <small>무기 / 공격력 +@item.AttackBonus</small>
                                }
                                else if (item.ItemType == "Armor")
                                {
                                    <small>방어구 / 방어력 +@item.DefenseBonus</small>
                                }
                                else
                                {
                                    <small>@item.ItemType</small>
                                }
                            </div>

                            @if (item.Name == "작은 포션")
                            {
                                <button @onclick="async () => await UseInventoryItem(currentItemName)">사용</button>
                            }
                            else if (item.ItemType == "Weapon" || item.ItemType == "Armor")
                            {
                                <button @onclick="async () => await EquipItem(currentItemName)">장착</button>
                            }
                        </div>
                    }
                }

                <p class="inventory-help">I 키로 닫기</p>
            </div>
        }

        <!-- ============================== -->
        <!-- 캐릭터창 -->
        <!-- ============================== -->
        @if (showCharacterWindow)
        {
            <div class="character-window">
                <h4>캐릭터</h4>
                <div>직업: @GetJobName(myJob)</div>
                <div>Lv: @myLevel</div>
                <div>HP: @myHp / @myMaxHp</div>
                <div>공격력: @myAttackPower</div>
                <div>방어력: @myDefense</div>
                <div>스탯포인트: @myStatPoint</div>
                <div>스킬포인트: @mySkillPoint</div>

                <hr />
                <div>무기: @(myWeapon?.Name ?? "없음")</div>
                <div>방어구: @(myArmor?.Name ?? "없음")</div>

                <hr />
                <div class="stat-row"><span>STR: @myStr</span><button @onclick='async () => await AddStat("STR")'>+</button></div>
                <div class="stat-row"><span>DEF: @myDef</span><button @onclick='async () => await AddStat("DEF")'>+</button></div>
                <div class="stat-row"><span>INT: @myInt</span><button @onclick='async () => await AddStat("INT")'>+</button></div>

                <p>S 키로 닫기</p>
            </div>
        }

        <!-- ============================== -->
        <!-- 장비창 -->
        <!-- ============================== -->
        @if (showEquipmentWindow)
        {
            <div class="equipment-window">
                <h4>장비창</h4>

                <div class="equipment-slot">
                    <strong>무기</strong>
                    @if (myWeapon == null)
                    {
                        <span>없음</span>
                    }
                    else
                    {
                        <span>@myWeapon.Name</span>
                        <small>공격력 +@myWeapon.AttackBonus</small>
                        <button @onclick='async () => await UnequipItem("Weapon")'>해제</button>
                    }
                </div>

                <div class="equipment-slot">
                    <strong>방어구</strong>
                    @if (myArmor == null)
                    {
                        <span>없음</span>
                    }
                    else
                    {
                        <span>@myArmor.Name</span>
                        <small>방어력 +@myArmor.DefenseBonus</small>
                        <button @onclick='async () => await UnequipItem("Armor")'>해제</button>
                    }
                </div>

                <p>E 키로 닫기</p>
            </div>
        }

        <!-- ============================== -->
        <!-- 전직창 -->
        <!-- ============================== -->
        @if (showJobWindow)
        {
            <div class="job-window">
                <h4>전직</h4>
                <div>현재 직업: @GetJobName(myJob)</div>
                <div>현재 레벨: @myLevel</div>

                @if (myJob == JobType.Beginner)
                {
                    @if (myLevel >= 8)
                    {
                        <button @onclick="async () => await ChangeJob(JobType.Mage)">마법사 전직 - 8레벨</button>
                    }

                    @if (myLevel >= 10)
                    {
                        <button @onclick="async () => await ChangeJob(JobType.Warrior)">전사 전직 - 10레벨</button>
                        <button @onclick="async () => await ChangeJob(JobType.Thief)">도적 전직 - 10레벨</button>
                        <button @onclick="async () => await ChangeJob(JobType.Archer)">궁수 전직 - 10레벨</button>
                    }

                    @if (myLevel < 8)
                    {
                        <p>8레벨부터 마법사 전직 가능</p>
                    }
                    else if (myLevel < 10)
                    {
                        <p>10레벨부터 전사/도적/궁수 전직 가능</p>
                    }
                }
                else
                {
                    <p>이미 전직 완료</p>
                    <p>전직 이후 레벨업마다 스킬포인트 +1</p>
                }

                <p>J 키로 닫기</p>
            </div>
        }

        <!-- ============================== -->
        <!-- 스킬창 -->
        <!-- ============================== -->
        @if (showSkillWindow)
        {
            <div class="skill-window">
                <h4>스킬창</h4>
                <p class="skill-desc">스킬포인트: @mySkillPoint</p>
                <p class="skill-desc">배운 스킬만 퀵슬롯에 등록할 수 있습니다.</p>

                @if (myJob == JobType.Beginner)
                {
                    <p>전직 후부터 직업 스킬을 배울 수 있습니다.</p>
                    <p>J 키로 전직창 열기</p>
                }

                @foreach (var skill in GetVisibleSkillDefinitions())
                {
                    var learned = myLearnedSkills.FirstOrDefault(s => s.SkillId == skill.SkillId);
                    var learnedLevel = learned?.Level ?? 0;
                    var canLearn = myJob != JobType.Beginner && skill.RequiredJob == myJob && myLevel >= skill.RequiredLevel;

                    <div class="skill-book-item">
                        <strong>@skill.Name</strong>
                        <small>@skill.Description</small>
                        <small>필요 직업: @GetJobName(skill.RequiredJob) / 필요 레벨: @skill.RequiredLevel</small>
                        <small>레벨: @(learnedLevel == 0 ? "미습득" : $"{learnedLevel}/{skill.MaxLevel}")</small>
                        <small>데미지: @skill.GetDamage(Math.Max(1, learnedLevel == 0 ? 1 : learnedLevel)) / 타격수: @skill.GetHitCount(Math.Max(1, learnedLevel == 0 ? 1 : learnedLevel)) / 타깃수: @skill.GetTargetCount(Math.Max(1, learnedLevel == 0 ? 1 : learnedLevel))</small>

                        @if (skill.SkillId != "basic_strike")
                        {
                            <button disabled="@(!canLearn || mySkillPoint <= 0 || learnedLevel >= skill.MaxLevel)"
                                    @onclick="async () => await LearnOrLevelUpSkill(skill.SkillId)">
                                @(learnedLevel == 0 ? "배우기" : "레벨업")
                            </button>
                        }

                        @if (learned != null)
                        {
                            <div class="skill-assign-buttons">
                                @for (int slot = 1; slot <= 9; slot++)
                                {
                                    var currentSlot = slot;
                                    <button @onclick="async () => await SetSkillSlot(currentSlot, skill.SkillId)">@currentSlot 번</button>
                                }
                            </div>
                        }
                    </div>
                }

                <hr />
                <strong>현재 퀵슬롯</strong>
                @for (int slot = 1; slot <= 9; slot++)
                {
                    var slotInfo = mySkillSlots.FirstOrDefault(s => s.Slot == slot);
                    var skillName = GetSkillName(slotInfo?.SkillId ?? "");
                    <div class="skill-slot-ui">
                        <span>@slot 번</span>
                        <strong>@(string.IsNullOrWhiteSpace(skillName) ? "비어있음" : skillName)</strong>
                    </div>
                }

                <p>K 키로 닫기</p>
            </div>
        }

        <!-- ============================== -->
        <!-- 이펙트 -->
        <!-- ============================== -->
        @if (showAttackEffect)
        {
            <div class="attack-effect" style="left:@($"{myX}px"); top:@($"{myY}px");"></div>
        }

        @if (showSkillEffect)
        {
            <div class="fireball-effect" style="left:@($"{myX}px"); top:@($"{myY}px");">✨</div>
        }

        <!-- ============================== -->
        <!-- 퀵슬롯 바 -->
        <!-- ============================== -->
        <div class="quick-slot-bar">
            @for (int slot = 1; slot <= 9; slot++)
            {
                var slotInfo = mySkillSlots.FirstOrDefault(s => s.Slot == slot);
                var skill = SkillDatabase.GetSkill(slotInfo?.SkillId ?? "");
                <div class="quick-slot">
                    <strong>@slot</strong>
                    <span>@(skill?.Name ?? "비어있음")</span>
                    @if (GetCooldownLeft(slot) > 0)
                    {
                        <div class="cooldown-cover">@GetCooldownLeft(slot)</div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private HubConnection? hubConnection;
    private DotNetObjectReference<object>? dotNetRef;

    private string playerName = "";
    private string roomCode = "room1";
    private string playerImage = "/images/player/down.png";
    private bool joined = false;

    private int myX = 400;
    private int myY = 250;
    private int myHp = 100;
    private int myMaxHp = 100;
    private int myLevel = 1;
    private int myExp = 0;
    private int myGold = 0;

    private int myStr = 1;
    private int myDef = 1;
    private int myInt = 1;
    private int myStatPoint = 0;
    private int mySkillPoint = 0;
    private int myAttackPower = 10;
    private int myDefense = 0;

    private JobType myJob = JobType.Beginner;
    private MapType myCurrentMap = MapType.Town;

    private EquipmentItem? myWeapon;
    private EquipmentItem? myArmor;

    private List<PlayerState> players = new();
    private List<MonsterState> monsters = new();
    private List<DroppedItem> droppedItems = new();
    private List<InventoryItem> myInventory = new();
    private List<SkillSlot> mySkillSlots = new();
    private List<PlayerSkillState> myLearnedSkills = new();
    private List<PlayerQuestState> myQuests = new();

    private bool showInventory = false;
    private bool showSkillWindow = false;
    private bool showCharacterWindow = false;
    private bool showEquipmentWindow = false;
    private bool showJobWindow = false;

    private bool canDash = true;
    private bool isDashing = false;
    private bool showAttackEffect = false;
    private bool showSkillEffect = false;
    private bool showShop = false;
    private bool showNpcDialog = false;

    private bool showPortalConfirm = false;
    private PortalState? selectedPortal = null;
    private NpcState? selectedNpc = null;
    private string npcMessage = "";

    private Dictionary<int, DateTime> skillCooldownEnds = new();

    private List<QuestState> questDefinitions = new()
    {
        new QuestState { QuestId = "merchant_slime", QuestName = "상인의 부탁", Description = "슬라임 3마리를 처치하세요.", TargetMonsterType = MonsterType.Slime, RequiredCount = 3, RewardGold = 50, RewardExp = 30, RewardItemName = "초보자 검", RewardItemType = "Weapon", RewardAttackBonus = 3, RewardRarity = "Normal" },
        new QuestState { QuestId = "hunter_goblin", QuestName = "사냥꾼의 의뢰", Description = "고블린 2마리를 처치하세요.", TargetMonsterType = MonsterType.Goblin, RequiredCount = 2, RewardGold = 120, RewardExp = 80, RewardItemName = "고블린 갑옷", RewardItemType = "Armor", RewardDefenseBonus = 8, RewardRarity = "Rare" },
        new QuestState { QuestId = "boss_clear", QuestName = "보스 토벌", Description = "보스 몬스터 1마리를 처치하세요.", TargetMonsterType = MonsterType.Boss, RequiredCount = 1, RewardGold = 300, RewardExp = 200, RewardItemName = "용사의 검", RewardItemType = "Weapon", RewardAttackBonus = 30, RewardRarity = "Epic" }
    };

    private List<PortalState> portals = new()
    {
        new PortalState { Name = "사냥터 입구", FromMap = MapType.Town, ToMap = MapType.Field, X = 850, Y = 300, TargetX = 150, TargetY = 300, Message = "사냥터로 이동할까요?" },
        new PortalState { Name = "마을 귀환", FromMap = MapType.Field, ToMap = MapType.Town, X = 100, Y = 300, TargetX = 800, TargetY = 300, Message = "마을로 돌아갈까요?" },
        new PortalState { Name = "보스방 입구", FromMap = MapType.Field, ToMap = MapType.BossRoom, X = 900, Y = 550, TargetX = 150, TargetY = 300, Message = "보스방으로 이동할까요?" },
        new PortalState { Name = "사냥터 귀환", FromMap = MapType.BossRoom, ToMap = MapType.Field, X = 100, Y = 300, TargetX = 850, TargetY = 500, Message = "사냥터로 돌아갈까요?" }
    };

    private List<NpcState> npcs = new()
    {
        new NpcState { Name = "상인", X = 500, Y = 300, Message = "어서 와! 슬라임 때문에 장사가 힘들어.", QuestId = "merchant_slime" },
        new NpcState { Name = "사냥꾼", X = 650, Y = 300, Message = "고블린을 조심해. 꽤 성가신 놈들이야.", QuestId = "hunter_goblin" },
        new NpcState { Name = "기사단장", X = 350, Y = 300, Message = "보스 몬스터를 토벌할 용사가 필요하다.", QuestId = "boss_clear" }
    };

    protected override async Task OnInitializedAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/gamehub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<List<PlayerState>>("UpdatePlayers", UpdatePlayers);
        hubConnection.On<List<MonsterState>>("UpdateMonsters", UpdateMonsters);
        hubConnection.On<List<DroppedItem>>("UpdateDrops", UpdateDrops);

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("SignalR 연결 실패: " + ex.Message);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create((object)this);
            await JS.InvokeVoidAsync("gameInput.init", dotNetRef);
        }
    }

    private async Task JoinGame()
    {
        if (string.IsNullOrWhiteSpace(playerName))
            playerName = "Player";

        if (string.IsNullOrWhiteSpace(roomCode))
            roomCode = "room1";

        joined = true;
        StateHasChanged();

        if (hubConnection == null)
            return;

        await hubConnection.SendAsync("JoinGame", roomCode, playerName);
        AiService.Start(hubConnection);
    }

    private void UpdatePlayers(List<PlayerState> updatedPlayers)
    {
        players = updatedPlayers;
        var me = players.FirstOrDefault(p => p.Name == playerName);

        if (me != null)
        {
            myX = me.X;
            myY = me.Y;
            myHp = me.Hp;
            myMaxHp = me.MaxHp;
            myLevel = me.Level;
            myExp = me.Exp;
            myGold = me.Gold;
            myCurrentMap = me.CurrentMap;
            myStr = me.Str;
            myDef = me.Def;
            myInt = me.Int;
            myStatPoint = me.StatPoint;
            mySkillPoint = me.SkillPoint;
            myAttackPower = me.AttackPower;
            myDefense = me.Defense;
            myJob = me.Job;
            myInventory = me.Inventory;
            mySkillSlots = me.SkillSlots;
            myLearnedSkills = me.LearnedSkills;
            myWeapon = me.Weapon;
            myArmor = me.Armor;
            myQuests = me.Quests;
        }

        InvokeAsync(StateHasChanged);
    }

    private void UpdateMonsters(List<MonsterState> updatedMonsters)
    {
        monsters = updatedMonsters;
        InvokeAsync(StateHasChanged);
    }

    private void UpdateDrops(List<DroppedItem> updatedDrops)
    {
        droppedItems = updatedDrops;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnKeyDown(string key)
    {
        switch (key)
        {
            case "ArrowUp":
                if (TryOpenPortalConfirm()) return;
                await MovePlayer(0, -10, "up");
                break;
            case "ArrowDown": await MovePlayer(0, 10, "down"); break;
            case "ArrowLeft": await MovePlayer(-10, 0, "left"); break;
            case "ArrowRight": await MovePlayer(10, 0, "right"); break;
            case "Control": await AttackMonster(); break;
            case "Shift": await Dash(); break;
            case "1": await UseSkill(1); break;
            case "2": await UseSkill(2); break;
            case "3": await UseSkill(3); break;
            case "4": await UseSkill(4); break;
            case "5": await UseSkill(5); break;
            case "6": await UseSkill(6); break;
            case "7": await UseSkill(7); break;
            case "8": await UseSkill(8); break;
            case "9": await UseSkill(9); break;
            case "i": case "I": showInventory = !showInventory; await InvokeAsync(StateHasChanged); break;
            case "k": case "K": showSkillWindow = !showSkillWindow; await InvokeAsync(StateHasChanged); break;
            case "s": case "S": showCharacterWindow = !showCharacterWindow; await InvokeAsync(StateHasChanged); break;
            case "e": case "E": showEquipmentWindow = !showEquipmentWindow; await InvokeAsync(StateHasChanged); break;
            case "j": case "J": showJobWindow = !showJobWindow; await InvokeAsync(StateHasChanged); break;
            case "z": case "Z": await PickupOrInteract(); break;
        }
    }

    private async Task MovePlayer(int moveX, int moveY, string direction)
    {
        int nextX = myX + moveX;
        int nextY = myY + moveY;

        if (IsBlockedTile(nextX, nextY))
            return;

        var result = InputService.Move(myX, myY, moveX, moveY, direction);
        myX = result.x;
        myY = result.y;

        playerImage = direction switch
        {
            "up" => "/images/player/up.png",
            "down" => "/images/player/down.png",
            "left" => "/images/player/left.png",
            "right" => "/images/player/right.png",
            _ => playerImage
        };

        CloseNpcDialogIfFar();
        await SyncPlayerPosition();
    }

    private async Task Dash()
    {
        if (!canDash) return;

        canDash = false;
        isDashing = true;

        var result = InputService.Dash(myX, myY);

        if (!IsBlockedTile(result.x, result.y))
        {
            myX = result.x;
            myY = result.y;
            await SyncPlayerPosition();
        }

        await Task.Delay(150);
        isDashing = false;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(850);
        canDash = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AttackMonster()
    {
        showAttackEffect = true;
        await InvokeAsync(StateHasChanged);

        if (hubConnection?.State == HubConnectionState.Connected)
            await hubConnection.SendAsync("AttackMonster");

        await Task.Delay(150);
        showAttackEffect = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UseSkill(int slot)
    {
        var slotInfo = mySkillSlots.FirstOrDefault(s => s.Slot == slot);
        var skill = SkillDatabase.GetSkill(slotInfo?.SkillId ?? "");

        if (slotInfo == null || skill == null)
            return;

        if (GetCooldownLeft(slot) > 0)
            return;

        skillCooldownEnds[slot] = DateTime.Now.AddSeconds(skill.CooldownSeconds);

        showSkillEffect = true;
        await InvokeAsync(StateHasChanged);

        if (hubConnection?.State == HubConnectionState.Connected)
            await hubConnection.SendAsync("UseSkillFromSlot", slot);

        await Task.Delay(250);
        showSkillEffect = false;
        await InvokeAsync(StateHasChanged);
    }

    private int GetCooldownLeft(int slot)
    {
        if (!skillCooldownEnds.ContainsKey(slot))
            return 0;

        var left = skillCooldownEnds[slot] - DateTime.Now;
        return left.TotalSeconds <= 0 ? 0 : (int)Math.Ceiling(left.TotalSeconds);
    }

