    protected override async Task OnInitializedAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/gamehub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<List<PlayerState>>("UpdatePlayers", UpdatePlayers);
        hubConnection.On<List<MonsterState>>("UpdateMonsters", UpdateMonsters);
        hubConnection.On<List<DroppedItem>>("UpdateDrops", UpdateDrops);

        await hubConnection.StartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create((object)this);
            await JS.InvokeVoidAsync("gameInput.init", dotNetRef);
        }
    }

    private async Task JoinGame()
    {
        if (string.IsNullOrWhiteSpace(playerName)) playerName = "Player";
        if (string.IsNullOrWhiteSpace(roomCode)) roomCode = "room1";
        joined = true;
        StateHasChanged();

        if (hubConnection != null)
        {
            await hubConnection.SendAsync("JoinGame", roomCode, playerName);
            AiService.Start(hubConnection);
        }
    }

    private void UpdatePlayers(List<PlayerState> updatedPlayers)
    {
        players = updatedPlayers;
        var me = players.FirstOrDefault(p => p.Name == playerName);
        if (me != null)
        {
            myX = me.X; myY = me.Y; myHp = me.Hp; myMaxHp = me.MaxHp; myLevel = me.Level; myExp = me.Exp; myGold = me.Gold;
            myCurrentMap = me.CurrentMap; myStr = me.Str; myDef = me.Def; myInt = me.Int; myStatPoint = me.StatPoint; mySkillPoint = me.SkillPoint;
            myAttackPower = me.AttackPower; myDefense = me.Defense; myJob = me.Job;
            myInventory = me.Inventory; mySkillSlots = me.SkillSlots; myLearnedSkills = me.LearnedSkills; myQuests = me.Quests;
            myWeapon = me.Weapon; myArmor = me.Armor;
            mySkinColor = me.SkinColor;
            myHairColor = me.HairColor;
            myOutfitColor = me.OutfitColor;
            myHairStyle = me.HairStyle;
            myFaceIcon = me.FaceIcon;
        }
        InvokeAsync(StateHasChanged);
    }

    private void UpdateMonsters(List<MonsterState> updatedMonsters) { monsters = updatedMonsters; InvokeAsync(StateHasChanged); }
    private void UpdateDrops(List<DroppedItem> updatedDrops) { droppedItems = updatedDrops; InvokeAsync(StateHasChanged); }

    [JSInvokable]
    public async Task OnKeyDown(string key)
    {
        switch (key)
        {
            case "ArrowUp":
                if (TryOpenPortalConfirm()) return;
                if (TryEnterBuilding()) return;
                await MovePlayer(0, -10, "up");
                break;
            case "ArrowDown": await MovePlayer(0, 10, "down"); break;
            case "ArrowLeft": await MovePlayer(-10, 0, "left"); break;
            case "ArrowRight": await MovePlayer(10, 0, "right"); break;
            case "Control": await AttackMonster(); break;
            case "Shift": await Dash(); break;
            case "1": await UseSkill(1); break;
            case "2": await UseSkill(2); break;
            case "3": await UseSkill(3); break;
            case "4": await UseSkill(4); break;
            case "5": await UseSkill(5); break;
            case "6": await UseSkill(6); break;
            case "7": await UseSkill(7); break;
            case "8": await UseSkill(8); break;
            case "9": await UseSkill(9); break;
            case "i": case "I": showInventory = !showInventory; await InvokeAsync(StateHasChanged); break;
            case "k": case "K": showSkillWindow = !showSkillWindow; await InvokeAsync(StateHasChanged); break;
            case "s": case "S": showCharacterWindow = !showCharacterWindow; await InvokeAsync(StateHasChanged); break;
            case "e": case "E": showEquipmentWindow = !showEquipmentWindow; await InvokeAsync(StateHasChanged); break;
            case "c": case "C": showCustomizeWindow = !showCustomizeWindow; await InvokeAsync(StateHasChanged); break;
            case "z": case "Z": await PickupOrInteract(); break;
        }
    }

    private bool TryEnterBuilding()
    {
        if (myCurrentMap != MapType.Town) return false;
        var building = buildings.FirstOrDefault(b => Math.Abs(b.X - myX) < 90 && Math.Abs(b.Y - myY) < 80);
        if (building == null) return false;
        currentBuilding = building;
        InvokeAsync(StateHasChanged);
        return true;
    }

    private void CloseBuilding() => currentBuilding = null;

    private async Task PickupOrInteract()
    {
        if (TryEnterBuilding()) return;
        if (hubConnection?.State == HubConnectionState.Connected) await hubConnection.SendAsync("PickupItem");
    }

    private bool TryOpenPortalConfirm()
    {
        var portal = portals.FirstOrDefault(p => p.FromMap == myCurrentMap && Math.Abs(p.X - myX) < 70 && Math.Abs(p.Y - myY) < 70);
        if (portal == null) return false;
        selectedPortal = portal;
        showPortalConfirm = true;
        InvokeAsync(StateHasChanged);
        return true;
    }

    private async Task ConfirmPortalMove()
    {
        if (selectedPortal == null) return;
        if (hubConnection?.State == HubConnectionState.Connected)
        {
            await hubConnection.SendAsync("ChangeMap", selectedPortal.ToMap, selectedPortal.TargetX, selectedPortal.TargetY);
        }
        showPortalConfirm = false;
        selectedPortal = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CancelPortalMove()
    {
        showPortalConfirm = false;
        selectedPortal = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task MovePlayer(int moveX, int moveY, string direction)
    {
        int nextX = myX + moveX;
        int nextY = myY + moveY;
        if (IsBlockedTile(nextX, nextY)) return;

        var result = InputService.Move(myX, myY, moveX, moveY, direction);
        myX = result.x;
        myY = result.y;
        playerImage = direction switch
        {
            "up" => "/images/player/up.png",
            "down" => "/images/player/down.png",
            "left" => "/images/player/left.png",
            "right" => "/images/player/right.png",
            _ => playerImage
        };
        await SyncPlayerPosition();
    }

    private async Task Dash()
    {
        if (!canDash) return;
        canDash = false;
        isDashing = true;
        var result = InputService.Dash(myX, myY);
        if (!IsBlockedTile(result.x, result.y))
        {
            myX = result.x;
            myY = result.y;
            await SyncPlayerPosition();
        }
        await Task.Delay(150);
        isDashing = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(850);
        canDash = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AttackMonster()
    {
        showAttackEffect = true;
        await InvokeAsync(StateHasChanged);
        if (hubConnection?.State == HubConnectionState.Connected) await hubConnection.SendAsync("AttackMonster");
        await Task.Delay(150);
        showAttackEffect = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UseSkill(int slot)
    {
        var slotInfo = mySkillSlots.FirstOrDefault(s => s.Slot == slot);
        if (slotInfo == null || string.IsNullOrWhiteSpace(slotInfo.SkillId)) return;
        var skill = SkillDatabase.GetSkill(slotInfo.SkillId);
        if (skill == null) return;
        if (GetCooldownLeft(slot) > 0) return;

        skillCooldownEnds[slot] = DateTime.Now.AddSeconds(skill.CooldownSeconds);
        if (hubConnection?.State == HubConnectionState.Connected) await hubConnection.SendAsync("UseSkillFromSlot", slot);
        await InvokeAsync(StateHasChanged);
    }

    private int GetCooldownLeft(int slot)
    {
        if (!skillCooldownEnds.ContainsKey(slot)) return 0;
        var left = skillCooldownEnds[slot] - DateTime.Now;
        return left.TotalSeconds <= 0 ? 0 : (int)Math.Ceiling(left.TotalSeconds);
    }

    private async Task SyncPlayerPosition()
    {
        if (hubConnection?.State == HubConnectionState.Connected) await hubConnection.SendAsync("MovePlayer", myX, myY);
    }

