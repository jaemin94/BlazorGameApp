    private async Task PickupOrInteract()
    {
        var npc = npcs.FirstOrDefault(n => myCurrentMap == MapType.Town && Math.Abs(n.X - myX) < 80 && Math.Abs(n.Y - myY) < 80);
        if (npc != null)
        {
            selectedNpc = npc;
            npcMessage = npc.Message;
            showNpcDialog = true;
            showShop = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (hubConnection?.State == HubConnectionState.Connected)
            await hubConnection.SendAsync("PickupItem");
    }

