@page "/game"
@using Microsoft.AspNetCore.SignalR.Client
@using MyBlazorApp.Models
@using MyBlazorApp.Services
@using Microsoft.JSInterop
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject GameInputService InputService
@inject GameAiService AiService

@implements IAsyncDisposable

<h3>멀티 RPG 테스트</h3>

@if (!joined)
{
    <div class="join-box">
        <input @bind="playerName" placeholder="닉네임" />
        <input @bind="roomCode" placeholder="방 코드" />
        <button @onclick="JoinGame">입장</button>
    </div>
}
else
{
    <div class="game-area">
        <div class="tile-map">
            @for (int y = 0; y < 13; y++)
            {
                @for (int x = 0; x < 20; x++)
                {
                    <div class="@GetTileClass(x, y)"></div>
                }
            }
        </div>

        <div class="map-name">@GetMapName(myCurrentMap)</div>

        @foreach (var building in buildings.Where(b => myCurrentMap == MapType.Town))
        {
            <div class="building" style="left:@($"{building.X}px"); top:@($"{building.Y}px"); width:@($"{building.Width}px"); height:@($"{building.Height}px");">
                <div class="building-icon">@building.Icon</div>
                <div class="building-name">@building.Name</div>
            </div>
        }

        @foreach (var portal in portals.Where(p => p.FromMap == myCurrentMap))
        {
            <div class="portal" style="left:@($"{portal.X}px"); top:@($"{portal.Y}px");">
                🌀
                <div>@portal.Name</div>
            </div>
        }

        @if (showPortalConfirm && selectedPortal != null)
        {
            <div class="modal-window small-window">
                <h4>포탈 이동</h4>
                <p>@selectedPortal.Message</p>
                <div class="button-row">
                    <button @onclick="ConfirmPortalMove">예</button>
                    <button class="danger" @onclick="CancelPortalMove">아니오</button>
                </div>
            </div>
        }

        @if (currentBuilding != null)
        {
            <div class="modal-window building-inner-window">
                <div class="window-title">
                    <h4>@currentBuilding.Name 내부</h4>
                    <button class="x-button" @onclick="CloseBuilding">X</button>
                </div>

                <div class="scroll-body">
                    @if (currentBuilding.Type == BuildingType.PotionShop)
                    {
                        <div class="npc-card"><strong>물약상인</strong><p>체력이 부족하면 포션을 챙겨가세요.</p></div>
                        @RenderShop(BuildingType.PotionShop)
                    }
                    else if (currentBuilding.Type == BuildingType.WeaponShop)
                    {
                        <div class="npc-card"><strong>무기상인</strong><p>좋은 무기는 사냥 속도를 바꿔줍니다.</p></div>
                        @RenderShop(BuildingType.WeaponShop)
                    }
                    else if (currentBuilding.Type == BuildingType.ArmorShop)
                    {
                        <div class="npc-card"><strong>방어구상인</strong><p>강한 몬스터를 상대하려면 방어구가 필요합니다.</p></div>
                        @RenderShop(BuildingType.ArmorShop)
                    }
                    else if (currentBuilding.Type == BuildingType.JobHall)
                    {
                        <div class="npc-card"><strong>전직관리관</strong><p>조건을 만족하면 전직할 수 있습니다.</p></div>
                        @RenderJobNpc()
                    }
                    else if (currentBuilding.Type == BuildingType.QuestHall)
                    {
                        <div class="npc-card"><strong>의뢰관리인</strong><p>마을의 의뢰를 확인하세요.</p></div>
                        @RenderQuestNpc()
                    }
                </div>
            </div>
        }

        <div class="status-box">
            <div>닉네임: @playerName</div>
            <div>직업: @GetJobName(myJob)</div>
            <div>HP: @myHp / @myMaxHp</div>
            <div>Lv: @myLevel / EXP: @myExp</div>
            <div>Gold: @myGold</div>
            <div>공격력: @myAttackPower / 방어력: @myDefense</div>
            <div>스탯P: @myStatPoint / 스킬P: @mySkillPoint</div>
            <div>Dash: @(canDash ? "가능" : "쿨타임")</div>
        </div>

        <div class="player @(isDashing ? "dash-effect" : "")" style="left:@($"{myX}px"); top:@($"{myY}px");">
            <div class="name">@playerName</div>
            <div class="custom-avatar" style="--skin:@mySkinColor; --hair:@myHairColor; --outfit:@myOutfitColor;">
                <div class="avatar-head">
                    <div class="avatar-hair hair-@myHairStyle"></div>
                    <span class="avatar-face">@myFaceIcon</span>
                </div>
                <div class="avatar-body"></div>
            </div>
        </div>

        @foreach (var player in players.Where(p => p.Name != playerName && p.CurrentMap == myCurrentMap))
        {
            <div class="player" style="left:@($"{player.X}px"); top:@($"{player.Y}px");">
                <div class="name">@player.Name</div>
                <div class="custom-avatar" style="--skin:@player.SkinColor; --hair:@player.HairColor; --outfit:@player.OutfitColor;">
                    <div class="avatar-head">
                        <div class="avatar-hair hair-@player.HairStyle"></div>
                        <span class="avatar-face">@player.FaceIcon</span>
                    </div>
                    <div class="avatar-body"></div>
                </div>
            </div>
        }

        @foreach (var monster in monsters)
        {
            <div class="monster" style="left:@($"{monster.X}px"); top:@($"{monster.Y}px");">
                <img src="@GetMonsterImage(monster.Type)" class="monster-img" />
                <div class="monster-name">@monster.Name</div>
                <div class="monster-hp">HP: @monster.Hp / @monster.MaxHp</div>
            </div>
        }

        @foreach (var item in droppedItems)
        {
            <div class="drop-item" style="left:@($"{item.X}px"); top:@($"{item.Y}px");">
                @if (item.IsGold)
                {
                    <div class="drop-gold">💰 @item.GoldAmount</div>
                }
                else
                {
                    <div class="drop-loot rarity-@item.Rarity.ToLower()">📦 @item.Name</div>
                }
            </div>
        }

        @if (showInventory)
        {
            <div class="rpg-window inventory-window">
                <div class="window-title">
                    <h4>가방</h4>
                    <button class="x-button" @onclick="() => showInventory = false">X</button>
                </div>

                <div class="inventory-tabs">
                    <button class="@(inventoryTab == InventoryTab.All ? "active" : "")" @onclick="() => inventoryTab = InventoryTab.All">전체</button>
                    <button class="@(inventoryTab == InventoryTab.Equipment ? "active" : "")" @onclick="() => inventoryTab = InventoryTab.Equipment">장비</button>
                    <button class="@(inventoryTab == InventoryTab.Potion ? "active" : "")" @onclick="() => inventoryTab = InventoryTab.Potion">물약</button>
                    <button class="@(inventoryTab == InventoryTab.Etc ? "active" : "")" @onclick="() => inventoryTab = InventoryTab.Etc">기타</button>
                </div>

                <div class="scroll-body inventory-scroll">
                    <div class="bag-grid">
                        @for (int i = 0; i < 16; i++)
                        {
                            var item = GetFilteredInventory().ElementAtOrDefault(i);
                            <div class="bag-slot">
                                @if (item != null)
                                {
                                    <div class="item-card rarity-@item.Rarity.ToLower()">
                                        <div class="item-icon">@GetItemIcon(item)</div>
                                        <strong>@item.Name</strong>
                                        <span>x @item.Count</span>

                                        <div class="item-tooltip">
                                            <b>@item.Name</b><br />
                                            종류: @GetItemTypeName(item.ItemType)<br />
                                            등급: @item.Rarity<br />
                                            @if (item.AttackBonus > 0)
                                            {
                                                <span>공격력 +@item.AttackBonus</span><br />
                                                <span>@GetWeaponCompareText(item)</span><br />
                                            }
                                            @if (item.DefenseBonus > 0)
                                            {
                                                <span>방어력 +@item.DefenseBonus</span><br />
                                                <span>@GetArmorCompareText(item)</span><br />
                                            }
                                            판매가: @item.SellPrice Gold
                                        </div>
                                    </div>

                                    <div class="item-actions">
                                        @if (item.ItemType == "Consumable")
                                        {
                                            <button @onclick="async () => await UseInventoryItem(item.Name)">사용</button>
                                        }
                                        @if (item.ItemType == "Weapon" || item.ItemType == "Armor")
                                        {
                                            <button @onclick="async () => await EquipItem(item.Name)">장착</button>
                                        }
                                        <button class="sell" @onclick="async () => await SellInventoryItem(item.Name)">판매</button>
                                    </div>
                                }
                                else
                                {
                                    <span class="empty-slot">빈칸</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @if (showEquipmentWindow)
        {
            <div class="rpg-window equipment-window">
                <div class="window-title">
                    <h4>장비창</h4>
                    <button class="x-button" @onclick="() => showEquipmentWindow = false">X</button>
                </div>

                <div class="scroll-body">
                    <div class="equipment-slot"><strong>무기</strong><span>@(myWeapon?.Name ?? "없음")</span>@if (myWeapon != null) { <button @onclick='async () => await UnequipItem("Weapon")'>해제</button> }</div>
                    <div class="equipment-slot"><strong>방어구</strong><span>@(myArmor?.Name ?? "없음")</span>@if (myArmor != null) { <button @onclick='async () => await UnequipItem("Armor")'>해제</button> }</div>
                    <hr />
                    <div>공격력: @myAttackPower</div>
                    <div>방어력: @myDefense</div>
                </div>
            </div>
        }

        @if (showCharacterWindow)
        {
            <div class="rpg-window character-window">
                <div class="window-title">
                    <h4>캐릭터</h4>
                    <button class="x-button" @onclick="() => showCharacterWindow = false">X</button>
                </div>

                <div class="scroll-body">
                    <div>직업: @GetJobName(myJob)</div>
                    <div>Lv: @myLevel</div>
                    <div>HP: @myHp / @myMaxHp</div>
                    <div>공격력: @myAttackPower</div>
                    <div>방어력: @myDefense</div>
                    <div>스탯포인트: @myStatPoint</div>
                    <hr />
                    <div class="stat-row"><span>STR: @myStr</span><button @onclick='async () => await AddStat("STR")'>+</button></div>
                    <div class="stat-row"><span>DEF: @myDef</span><button @onclick='async () => await AddStat("DEF")'>+</button></div>
                    <div class="stat-row"><span>INT: @myInt</span><button @onclick='async () => await AddStat("INT")'>+</button></div>
                </div>
            </div>
        }

        @if (showSkillWindow)
        {
            <div class="rpg-window skill-window">
                <div class="window-title">
                    <h4>스킬창</h4>
                    <button class="x-button" @onclick="() => showSkillWindow = false">X</button>
                </div>

                <div>직업: @GetJobName(myJob) / 스킬포인트: @mySkillPoint</div>
                <div class="scroll-body">
                    @foreach (var skill in GetVisibleSkills())
                    {
                        var learned = myLearnedSkills.FirstOrDefault(s => s.SkillId == skill.SkillId);
                        var learnedLevel = learned?.Level ?? 0;
                        <div class="skill-book-item">
                            <strong>@skill.Name</strong>
                            <small>@skill.Description</small>
                            <span>레벨: @learnedLevel / @skill.MaxLevel</span>
                            <span>데미지: @skill.GetDamage(Math.Max(1, learnedLevel)) / 타격수: @skill.GetHitCount(Math.Max(1, learnedLevel)) / 타깃수: @skill.GetTargetCount(Math.Max(1, learnedLevel))</span>

                            @if (skill.RequiredJob != JobType.Beginner)
                            {
                                <button @onclick="async () => await LearnOrLevelUpSkill(skill.SkillId)">배우기/레벨업</button>
                            }

                            @if (learned != null)
                            {
                                <div class="slot-buttons">
                                    @for (int slot = 1; slot <= 9; slot++)
                                    {
                                        var currentSlot = slot;
                                        <button @onclick="async () => await SetSkillSlot(currentSlot, skill.SkillId)">@slot</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (showCustomizeWindow)
        {
            <div class="rpg-window customize-window">
                <div class="window-title">
                    <h4>캐릭터 커스터마이징</h4>
                    <button class="x-button" @onclick="() => showCustomizeWindow = false">X</button>
                </div>

                <div class="scroll-body">
                    <div class="custom-preview">
                        <div class="custom-avatar big-avatar" style="--skin:@mySkinColor; --hair:@myHairColor; --outfit:@myOutfitColor;">
                            <div class="avatar-head">
                                <div class="avatar-hair hair-@myHairStyle"></div>
                                <span class="avatar-face">@myFaceIcon</span>
                            </div>
                            <div class="avatar-body"></div>
                        </div>
                    </div>

                    <div class="custom-section">
                        <strong>피부색</strong>
                        <div class="color-buttons">
                            @foreach (var color in skinColors)
                            {
                                var selectedColor = color;
                                <button class="color-dot @(mySkinColor == selectedColor ? "selected" : "")" style="background:@selectedColor" @onclick="() => mySkinColor = selectedColor"></button>
                            }
                        </div>
                    </div>

                    <div class="custom-section">
                        <strong>머리색</strong>
                        <div class="color-buttons">
                            @foreach (var color in hairColors)
                            {
                                var selectedColor = color;
                                <button class="color-dot @(myHairColor == selectedColor ? "selected" : "")" style="background:@selectedColor" @onclick="() => myHairColor = selectedColor"></button>
                            }
                        </div>
                    </div>

                    <div class="custom-section">
                        <strong>의상색</strong>
                        <div class="color-buttons">
                            @foreach (var color in outfitColors)
                            {
                                var selectedColor = color;
                                <button class="color-dot @(myOutfitColor == selectedColor ? "selected" : "")" style="background:@selectedColor" @onclick="() => myOutfitColor = selectedColor"></button>
                            }
                        </div>
                    </div>

                    <div class="custom-section">
                        <strong>헤어스타일</strong>
                        <div class="choice-buttons">
                            <button class="@(myHairStyle == "short" ? "active" : "")" @onclick='() => myHairStyle = "short"'>짧은머리</button>
                            <button class="@(myHairStyle == "long" ? "active" : "")" @onclick='() => myHairStyle = "long"'>긴머리</button>
                            <button class="@(myHairStyle == "spiky" ? "active" : "")" @onclick='() => myHairStyle = "spiky"'>삐죽머리</button>
                            <button class="@(myHairStyle == "bob" ? "active" : "")" @onclick='() => myHairStyle = "bob"'>단발</button>
                        </div>
                    </div>

                    <div class="custom-section">
                        <strong>표정</strong>
                        <div class="choice-buttons face-buttons">
                            @foreach (var face in faceIcons)
                            {
                                var selectedFace = face;
                                <button class="@(myFaceIcon == selectedFace ? "active" : "")" @onclick="() => myFaceIcon = selectedFace">@selectedFace</button>
                            }
                        </div>
                    </div>

                    <button class="save-custom-button" @onclick="SaveCharacterAppearance">외형 저장</button>
                    <p class="hint-text">C 키로 창을 열고 닫을 수 있습니다.</p>
                </div>
            </div>
        }

        @if (showAttackEffect)
        {
            <div class="attack-effect" style="left:@($"{myX}px"); top:@($"{myY}px");"></div>
        }

        <div class="quick-slot-bar">
            @foreach (var slot in mySkillSlots.OrderBy(s => s.Slot))
            {
                <div class="quick-slot">
                    <strong>@slot.Slot</strong>
                    <span>@(string.IsNullOrWhiteSpace(slot.SkillId) ? "빈 슬롯" : SkillDatabase.GetName(slot.SkillId))</span>
                    @if (GetCooldownLeft(slot.Slot) > 0)
                    {
                        <div class="cooldown-cover">@GetCooldownLeft(slot.Slot)</div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private HubConnection? hubConnection;
    private DotNetObjectReference<object>? dotNetRef;

    private string playerName = "";
    private string roomCode = "room1";
    private string playerImage = "/images/player/down.png";

    // 캐릭터 커스터마이징 상태
    private string mySkinColor = "#f2c7a5";
    private string myHairColor = "#2b1b12";
    private string myOutfitColor = "#2563eb";
    private string myHairStyle = "short";
    private string myFaceIcon = "🙂";

    private readonly List<string> skinColors = new() { "#f2c7a5", "#d8a47f", "#8d5524", "#ffe0bd" };
    private readonly List<string> hairColors = new() { "#2b1b12", "#7c2d12", "#facc15", "#111827", "#f8fafc" };
    private readonly List<string> outfitColors = new() { "#2563eb", "#16a34a", "#dc2626", "#7c3aed", "#f97316", "#0f172a" };
    private readonly List<string> faceIcons = new() { "🙂", "😐", "😎", "😡", "😊", "🤠" };
    private bool joined = false;

    private int myX = 400;
    private int myY = 250;
    private int myHp = 100;
    private int myMaxHp = 100;
    private int myLevel = 1;
    private int myExp = 0;
    private int myGold = 0;
    private int myStr = 1;
    private int myDef = 1;
    private int myInt = 1;
    private int myStatPoint = 0;
    private int mySkillPoint = 0;
    private int myAttackPower = 10;
    private int myDefense = 0;
    private JobType myJob = JobType.Beginner;
    private MapType myCurrentMap = MapType.Town;

    private bool showInventory = false;
    private bool showSkillWindow = false;
    private bool showCharacterWindow = false;
    private bool showEquipmentWindow = false;
    private bool showCustomizeWindow = false;
    private bool canDash = true;
    private bool isDashing = false;
    private bool showAttackEffect = false;

    private bool showPortalConfirm = false;
    private PortalState? selectedPortal = null;
    private BuildingState? currentBuilding = null;
    private InventoryTab inventoryTab = InventoryTab.All;

    private EquipmentItem? myWeapon;
    private EquipmentItem? myArmor;
    private List<PlayerState> players = new();
    private List<MonsterState> monsters = new();
    private List<DroppedItem> droppedItems = new();
    private List<InventoryItem> myInventory = new();
    private List<SkillSlot> mySkillSlots = new();
    private List<PlayerSkillState> myLearnedSkills = new();
    private List<PlayerQuestState> myQuests = new();
    private Dictionary<int, DateTime> skillCooldownEnds = new();

    private List<BuildingState> buildings = new()
    {
        new BuildingState { Name = "물약상점", Type = BuildingType.PotionShop, X = 220, Y = 180, Icon = "🧪", Message = "물약상점에 들어갈까요?" },
        new BuildingState { Name = "무기상점", Type = BuildingType.WeaponShop, X = 430, Y = 180, Icon = "⚔️", Message = "무기상점에 들어갈까요?" },
        new BuildingState { Name = "방어구상점", Type = BuildingType.ArmorShop, X = 640, Y = 180, Icon = "🛡️", Message = "방어구상점에 들어갈까요?" },
        new BuildingState { Name = "전직소", Type = BuildingType.JobHall, X = 340, Y = 430, Icon = "🏛️", Message = "전직소에 들어갈까요?" },
        new BuildingState { Name = "의뢰소", Type = BuildingType.QuestHall, X = 560, Y = 430, Icon = "📜", Message = "의뢰소에 들어갈까요?" }
    };

    private List<PortalState> portals = new()
    {
        new PortalState { Name = "사냥터 입구", FromMap = MapType.Town, ToMap = MapType.Field, X = 850, Y = 300, TargetX = 150, TargetY = 300, Message = "사냥터로 이동할까요?" },
        new PortalState { Name = "마을 귀환", FromMap = MapType.Field, ToMap = MapType.Town, X = 100, Y = 300, TargetX = 800, TargetY = 300, Message = "마을로 돌아갈까요?" },
        new PortalState { Name = "보스방 입구", FromMap = MapType.Field, ToMap = MapType.BossRoom, X = 900, Y = 550, TargetX = 150, TargetY = 300, Message = "보스방으로 이동할까요?" },
        new PortalState { Name = "사냥터 귀환", FromMap = MapType.BossRoom, ToMap = MapType.Field, X = 100, Y = 300, TargetX = 850, TargetY = 500, Message = "사냥터로 돌아갈까요?" }
    };

    private static readonly List<ShopItem> LocalShopItems = new()
    {
        new ShopItem { ShopType = BuildingType.PotionShop, Name = "작은 포션", ItemType = "Consumable", Price = 20, Rarity = "Normal" },
        new ShopItem { ShopType = BuildingType.PotionShop, Name = "중간 포션", ItemType = "Consumable", Price = 60, Rarity = "Rare" },
        new ShopItem { ShopType = BuildingType.WeaponShop, Name = "낡은 검", ItemType = "Weapon", Price = 100, AttackBonus = 5, Rarity = "Normal" },
        new ShopItem { ShopType = BuildingType.WeaponShop, Name = "초보자 지팡이", ItemType = "Weapon", Price = 150, AttackBonus = 4, Rarity = "Normal" },
        new ShopItem { ShopType = BuildingType.WeaponShop, Name = "초보 활", ItemType = "Weapon", Price = 180, AttackBonus = 7, Rarity = "Normal" },
        new ShopItem { ShopType = BuildingType.WeaponShop, Name = "단검", ItemType = "Weapon", Price = 160, AttackBonus = 6, Rarity = "Normal" },
        new ShopItem { ShopType = BuildingType.WeaponShop, Name = "고블린 검", ItemType = "Weapon", Price = 300, AttackBonus = 12, Rarity = "Rare" },
        new ShopItem { ShopType = BuildingType.ArmorShop, Name = "가죽 갑옷", ItemType = "Armor", Price = 120, DefenseBonus = 4, Rarity = "Normal" },
        new ShopItem { ShopType = BuildingType.ArmorShop, Name = "철 갑옷", ItemType = "Armor", Price = 350, DefenseBonus = 10, Rarity = "Rare" }
    };

    private RenderFragment RenderShop(BuildingType type) => @<div class="shop-list">
        @foreach (var item in LocalShopItems.Where(i => i.ShopType == type))
        {
            <div class="shop-item rarity-@item.Rarity.ToLower()">
                <div>
                    <strong>@GetItemIcon(item.ItemType) @item.Name</strong>
                    <small>@GetItemTypeName(item.ItemType) / @item.Rarity</small>
                    @if (item.AttackBonus > 0) { <small>공격력 +@item.AttackBonus</small> }
                    @if (item.DefenseBonus > 0) { <small>방어력 +@item.DefenseBonus</small> }
                </div>
                <button @onclick="async () => await BuyShopItem(item.Name)">@item.Price Gold 구매</button>
            </div>
        }
    </div>;

    private RenderFragment RenderJobNpc() => @<div class="job-list">
