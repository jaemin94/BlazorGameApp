    // 퀘스트 상태 텍스트
    private string GetQuestText()
    {
        if (myQuests.Count == 0)
            return "없음";

        var active = myQuests.FirstOrDefault(q => !q.RewardReceived);

        if (active == null)
            return "완료";

        var quest = questDefinitions.FirstOrDefault(q => q.QuestId == active.QuestId);

        if (quest == null)
            return "진행중";

        if (active.Completed)
            return $"{quest.QuestName} 보상 가능";

        return $"{quest.QuestName} {active.CurrentCount}/{quest.RequiredCount}";
    }

    // 맵 타일 클래스
    private string GetTileClass(int x, int y)
    {
        if (myCurrentMap == MapType.Town)
        {
            if (y == 0 || y == 12 || x == 0 || x == 19)
                return "tile wall";

            if (y == 5 || y == 6 || x == 10)
                return "tile town-road";

            if ((x >= 3 && x <= 5 && y >= 2 && y <= 4) ||
                (x >= 13 && x <= 15 && y >= 2 && y <= 4))
                return "tile house";

            if ((x == 2 && y == 9) || (x == 17 && y == 9))
                return "tile tree";

            return "tile town-grass";
        }

        if (myCurrentMap == MapType.Field)
        {
            if (y == 0 || y == 12 || x == 0 || x == 19)
                return "tile wall";

            if (y == 2 && x >= 4 && x <= 8)
                return "tile water";

            if (y == 8 && x >= 12 && x <= 15)
                return "tile rock";

            if (y == 6 || x == 2)
                return "tile dirt-road";

            return "tile field-grass";
        }

        if (myCurrentMap == MapType.BossRoom)
        {
            if (y == 0 || y == 12 || x == 0 || x == 19)
                return "tile boss-wall";

            if ((x == 3 && y == 3) || (x == 16 && y == 3) || (x == 3 && y == 9) || (x == 16 && y == 9))
                return "tile torch";

            return "tile boss-floor";
        }

        return "tile grass";
    }

    // 플레이어 충돌 체크
    private bool IsBlockedTile(int x, int y)
    {
        if (x < 24 || x > 976 || y < 24 || y > 626)
            return true;

        int tileX = x / 50;
        int tileY = y / 50;

        if (tileX <= 0 || tileX >= 19 || tileY <= 0 || tileY >= 12)
            return true;

        if (myCurrentMap == MapType.Field)
        {
            if (tileY == 2 && tileX >= 4 && tileX <= 8)
                return true;

            if (tileY == 8 && tileX >= 12 && tileX <= 15)
                return true;
        }

        return false;
    }

