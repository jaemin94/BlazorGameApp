    private void CloseNpcDialogIfFar()
    {
        if (selectedNpc == null) return;

        if (Math.Abs(selectedNpc.X - myX) > 120 || Math.Abs(selectedNpc.Y - myY) > 120)
        {
            showNpcDialog = false;
            showShop = false;
            selectedNpc = null;
        }
    }

    private bool TryOpenPortalConfirm()
    {
        var portal = portals.FirstOrDefault(p =>
            p.FromMap == myCurrentMap &&
            Math.Abs(p.X - myX) < 70 &&
            Math.Abs(p.Y - myY) < 70);

        if (portal == null) return false;

        selectedPortal = portal;
        showPortalConfirm = true;
        InvokeAsync(StateHasChanged);
        return true;
    }

