    private string GetWeaponCompareText(InventoryItem item)
    {
        int current = myWeapon?.AttackBonus ?? 0;
        int diff = item.AttackBonus - current;
        return diff >= 0 ? $"현재 무기보다 +{diff}" : $"현재 무기보다 {diff}";
    }

    private string GetArmorCompareText(InventoryItem item)
    {
        int current = myArmor?.DefenseBonus ?? 0;
        int diff = item.DefenseBonus - current;
        return diff >= 0 ? $"현재 방어구보다 +{diff}" : $"현재 방어구보다 {diff}";
    }

