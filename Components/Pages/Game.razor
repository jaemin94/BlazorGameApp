    private List<InventoryItem> GetFilteredInventory()
    {
        return inventoryTab switch
        {
            InventoryTab.Equipment => myInventory.Where(i => i.ItemType == "Weapon" || i.ItemType == "Armor").ToList(),
            InventoryTab.Potion => myInventory.Where(i => i.ItemType == "Consumable").ToList(),
            InventoryTab.Etc => myInventory.Where(i => i.ItemType != "Weapon" && i.ItemType != "Armor" && i.ItemType != "Consumable").ToList(),
            _ => myInventory.ToList()
        };
    }

    private List<SkillDefinition> GetVisibleSkills()
    {
        return SkillDatabase.Skills
            .Where(s => s.RequiredJob == JobType.Beginner || s.RequiredJob == myJob)
            .ToList();
    }

