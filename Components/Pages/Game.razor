    };

    private string GetTileClass(int x, int y)
    {
        if (x == 0 || x == 19 || y == 0 || y == 12) return "tile wall";
        if (myCurrentMap == MapType.Town)
        {
            if (y == 6 || x == 9 || x == 10) return "tile town-road";
            return "tile town-grass";
        }
        if (myCurrentMap == MapType.BossRoom)
        {
            if (x == 0 || x == 19 || y == 0 || y == 12) return "tile wall";
            return "tile boss-floor";
        }
        if (y == 2 && x >= 4 && x <= 8) return "tile water";
        if (y == 8 && x >= 12 && x <= 15) return "tile wall";
        return "tile grass";
    }

    private bool IsBlockedTile(int x, int y)
    {
        if (x < 24 || x > 976 || y < 24 || y > 626) return true;
        int tileX = x / 50;
        int tileY = y / 50;
        if (tileX <= 0 || tileX >= 19 || tileY <= 0 || tileY >= 12) return true;
        if (myCurrentMap != MapType.Town)
        {
            if (tileY == 2 && tileX >= 4 && tileX <= 8) return true;
            if (tileY == 8 && tileX >= 12 && tileX <= 15) return true;
        }
        return false;
    }

    public async ValueTask DisposeAsync()
    {
        AiService.Stop();
        dotNetRef?.Dispose();
        if (hubConnection != null) await hubConnection.DisposeAsync();
    }
