    // 포탈 확인창 열기
    private bool TryOpenPortalConfirm()
    {
        var portal = portals.FirstOrDefault(p =>
            p.FromMap == myCurrentMap &&
            Math.Abs(p.X - myX) < 70 &&
            Math.Abs(p.Y - myY) < 70);

        if (portal == null)
            return false;

        selectedPortal = portal;
        showPortalConfirm = true;
        InvokeAsync(StateHasChanged);

        return true;
    }

    // 포탈 이동 확인
    private async Task ConfirmPortalMove()
    {
        if (selectedPortal == null)
            return;

        if (hubConnection?.State == HubConnectionState.Connected)
        {
            await hubConnection.SendAsync(
                "ChangeMap",
                selectedPortal.ToMap,
                selectedPortal.TargetX,
                selectedPortal.TargetY
            );
        }

        showPortalConfirm = false;
        selectedPortal = null;

        await InvokeAsync(StateHasChanged);
    }

    // 포탈 이동 취소
    private async Task CancelPortalMove()
    {
        showPortalConfirm = false;
        selectedPortal = null;
        await InvokeAsync(StateHasChanged);
    }

    // 줍기 또는 NPC 상호작용
    private async Task PickupOrInteract()
    {
        var npc = npcs.FirstOrDefault(n =>
            myCurrentMap == MapType.Town &&
            Math.Abs(n.X - myX) < 80 &&
            Math.Abs(n.Y - myY) < 80);

        if (npc != null)
        {
            selectedNpc = npc;
            npcMessage = npc.Message;
            showNpcDialog = true;
            showShop = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (hubConnection?.State == HubConnectionState.Connected)
            await hubConnection.SendAsync("PickupItem");
    }

    // NPC 창 닫기
    private void CloseNpcDialogIfFar()
    {
        if (selectedNpc == null)
            return;

        if (Math.Abs(selectedNpc.X - myX) > 110 || Math.Abs(selectedNpc.Y - myY) > 110)
        {
            selectedNpc = null;
            showNpcDialog = false;
            showShop = false;
        }
    }

    private void CloseShop()
    {
        selectedNpc = null;
        showShop = false;
